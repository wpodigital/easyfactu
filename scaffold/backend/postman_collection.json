    {
      "name": "Delete Invoice",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/invoices/:id",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "invoices", ":id"],
          "variable": [
            {
              "key": "id",
              "value": "1"
            }
