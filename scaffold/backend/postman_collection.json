              "key": "id",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "Get Invoice XML",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/invoices/:id/xml",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "invoices", ":id", "xml"],
          "variable": [
