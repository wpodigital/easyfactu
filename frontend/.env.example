# ─────────────────────────────────────────────────────────────────────────────
# EasyFactu – Frontend environment variables
# Copy this file to .env and adjust the values for your local setup.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Express backend API.
# In local development you can leave this blank: Vite will proxy /api/* requests
# to http://localhost:3000 automatically (see vite.config.ts).
# Set this in production to the public API URL, e.g.:
#   VITE_API_URL=https://api.myserver.com
VITE_API_URL=
