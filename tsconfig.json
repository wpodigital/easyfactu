{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "tests/**/*", "scaffold/backend/src/**/*"],
  "exclude": ["node_modules", "scaffold/backend/node_modules", "scaffold/backend/dist"]
}
